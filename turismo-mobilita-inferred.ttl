#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
<http://purl.org/dc/elements/1.1/date> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/eSedeDi
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/eSedeDi> rdf:type owl:ObjectProperty ;
                                                                             owl:inverseOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haSede> ;
                                                                             rdf:type owl:TransitiveProperty ;
                                                                             rdfs:comment "Relazione inversa di 'si trova in' che indica quali punti di interesse sono ospitati in un'area."@it ;
                                                                             rdfs:label "sedeDi"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/fornitoDa
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/fornitoDa> rdf:type owl:ObjectProperty ;
                                                                               owl:inverseOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/gestisce> ;
                                                                               rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                               rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Compagnia> ;
                                                                               rdfs:comment "Specifica la compagnia che gestisce il servizio di trasporto."@it ;
                                                                               rdfs:label "fornitoDa"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/gestisce
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/gestisce> rdf:type owl:ObjectProperty ;
                                                                              rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Compagnia> ;
                                                                              rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                              rdfs:comment "Specifica il mezzo di trasporto che effettua il servizio."@it ;
                                                                              rdfs:label "fornisce"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haDestinazioneFinale
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haDestinazioneFinale> rdf:type owl:ObjectProperty ,
                                                                                                   owl:FunctionalProperty ;
                                                                                          rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                                          rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/InfrastrutturaTrasporto> ;
                                                                                          rdfs:comment "Specifica l'unica e univoca infrastruttura logistica in cui termina definitivamente il servizio di trasporto."@it ;
                                                                                          rdfs:label "haDestinazioneFinale"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haPuntoArrivo
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haPuntoArrivo> rdf:type owl:ObjectProperty ,
                                                                                            owl:FunctionalProperty ;
                                                                                   rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                                   rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/InfrastrutturaTrasporto> ;
                                                                                   rdfs:comment "Indica l'infrastruttura logistica di destinazione finale del servizio di trasporto."@it ;
                                                                                   rdfs:label "haPuntoArrivo"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haPuntoPartenza
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haPuntoPartenza> rdf:type owl:ObjectProperty ;
                                                                                     owl:inverseOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/puntoPartenzaDi> ;
                                                                                     rdf:type owl:FunctionalProperty ;
                                                                                     rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                                     rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/InfrastrutturaTrasporto> ;
                                                                                     rdfs:comment "Indica l'infrastruttura logistica (es. aeroporto) da cui ha inizio il servizio di trasporto."@it ;
                                                                                     rdfs:label "haPuntoPartenza"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haSede
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haSede> rdf:type owl:ObjectProperty ,
                                                                                     owl:TransitiveProperty ;
                                                                            rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/EntitaGeografica> ;
                                                                            rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AreaGeografica> ;
                                                                            rdfs:comment "Relazione spaziale di inclusione che connette un'entità geografica o un punto di interesse alla sua area di appartenenza."@it ;
                                                                            rdfs:label "haSede"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haTappa
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haTappa> rdf:type owl:ObjectProperty ;
                                                                             rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Itinerario> ;
                                                                             rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/PuntoInteresse> ;
                                                                             rdfs:comment "Specifica i punti di interesse presenti nell'itinerario."@it ,
                                                                                          "haTappa"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/offreAccessoA
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/offreAccessoA> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/InfrastrutturaTrasporto> ;
                                                                                   rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AttrazioneTuristica> ;
                                                                                   rdfs:comment "Specifica le attrazioni turistiche raggiungibili utilizzando una determinata infrastruttura di trasporto."@it ;
                                                                                   rdfs:label "offreAccessoA"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/puntoPartenzaDi
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/puntoPartenzaDi> rdf:type owl:ObjectProperty ;
                                                                                     rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/InfrastrutturaTrasporto> ;
                                                                                     rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                                     rdfs:comment "Specifica quale mezzo di trasporto parte da un determinato nodo logistico."@it ;
                                                                                     rdfs:label "èPuntoPartenzaDi"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/raggiungeArea
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/raggiungeArea> rdf:type owl:ObjectProperty ,
                                                                                            owl:AsymmetricProperty ,
                                                                                            owl:IrreflexiveProperty ;
                                                                                   rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                                   rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AreaGeografica> ;
                                                                                   owl:propertyChainAxiom ( <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haPuntoArrivo>
                                                                                                            <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haSede>
                                                                                                          ) ;
                                                                                   rdfs:label "raggiungeAreaGeografica"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/utilizzaMezzo
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/utilizzaMezzo> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Itinerario> ;
                                                                                   rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                                   rdfs:comment "Specifica il mezzo di trasporto utilizzato nell'itinerario."@it ;
                                                                                   rdfs:label "utilizzaMezzo"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/vicinoA
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/vicinoA> rdf:type owl:ObjectProperty ;
                                                                             owl:inverseOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/vicinoA> ;
                                                                             rdf:type owl:SymmetricProperty ;
                                                                             rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/PuntoInteresse> ;
                                                                             rdfs:range <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/PuntoInteresse> ;
                                                                             rdfs:comment "Specifica i punti di interesse nelle vicinanze in modo simmetrico  (es: se l'Hotel è vicino al Museo, il Museo è vicino all'Hotel)."@it ;
                                                                             rdfs:label "vicinoA"@it .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/annoCostruzione
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/annoCostruzione> rdf:type owl:DatatypeProperty ,
                                                                                              owl:FunctionalProperty ;
                                                                                     rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AttrazioneTuristica> ;
                                                                                     rdfs:comment "Specifica l'anno di costruzione delle attrazioni turistiche"@it ;
                                                                                     rdfs:label "annoCostruzione"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/capacitaOspiti
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/capacitaOspiti> rdf:type owl:DatatypeProperty ,
                                                                                             owl:FunctionalProperty ;
                                                                                    rdfs:domain [ rdf:type owl:Class ;
                                                                                                  owl:unionOf ( <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto>
                                                                                                                <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/StrutturaRicettiva>
                                                                                                              )
                                                                                                ] ;
                                                                                    rdfs:comment "Specifica quanti posti ospita il mezzo di trasporto o la struttura ricettiva."@it ;
                                                                                    rdfs:label "capacitaOspiti"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/durataGiorni
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/durataGiorni> rdf:type owl:DatatypeProperty ,
                                                                                           owl:FunctionalProperty ;
                                                                                  rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Itinerario> ;
                                                                                  rdfs:comment "Specifica la durata in giorni dell'itinerario." ;
                                                                                  rdfs:label "durataGiorni"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haLatitudine
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haLatitudine> rdf:type owl:DatatypeProperty ;
                                                                                  rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/PuntoInteresse> ;
                                                                                  rdfs:range xsd:decimal ;
                                                                                  rdfs:comment "Specifica la latitudine di una determinata Area Geografica."@it ;
                                                                                  rdfs:label "haLatitudine"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haLongitudine
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haLongitudine> rdf:type owl:DatatypeProperty ;
                                                                                   rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/PuntoInteresse> ;
                                                                                   rdfs:range xsd:decimal ;
                                                                                   rdfs:comment "Specifica la longitudine di una determinata Area Geografica."@it ;
                                                                                   rdfs:label "haLongitudine"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haNumeroStelle
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haNumeroStelle> rdf:type owl:DatatypeProperty ,
                                                                                             owl:FunctionalProperty ;
                                                                                    rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Hotel> ;
                                                                                    rdfs:range [ rdf:type rdfs:Datatype ;
                                                                                                 owl:onDatatype xsd:integer ;
                                                                                                 owl:withRestrictions ( [ xsd:minInclusive 1
                                                                                                                        ]
                                                                                                                        [ xsd:maxInclusive 5
                                                                                                                        ]
                                                                                                                      )
                                                                                               ] ;
                                                                                    rdfs:comment "Specifica il numero di stelle di un determinato Hotel."@it ;
                                                                                    rdfs:label "haNumeroStelle"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haPopolazione
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haPopolazione> rdf:type owl:DatatypeProperty ,
                                                                                            owl:FunctionalProperty ;
                                                                                   rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AreaGeografica> ;
                                                                                   rdfs:range xsd:nonNegativeInteger ;
                                                                                   rdfs:comment "Specifica il numero di abitanti per una determinata Area Geografica"@it ;
                                                                                   rdfs:label "haPopolazione"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haSitoWeb
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haSitoWeb> rdf:type owl:DatatypeProperty ;
                                                                               rdfs:domain [ rdf:type owl:Class ;
                                                                                             owl:unionOf ( <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Compagnia>
                                                                                                           <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/PuntoInteresse>
                                                                                                         )
                                                                                           ] ;
                                                                               rdfs:range xsd:anyURI ;
                                                                               rdfs:comment "Specifica il sito della Compagnia o dell'AttrazioneTuristica."@it ;
                                                                               rdfs:label "haSitoWeb"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/numeroMezzo
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/numeroMezzo> rdf:type owl:DatatypeProperty ,
                                                                                          owl:FunctionalProperty ;
                                                                                 rdfs:domain <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                                 rdfs:range xsd:string ;
                                                                                 rdfs:comment "Speifica il numero del mezzo impiegato nel trasporto."@it ;
                                                                                 rdfs:label "numeroMezzo"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/prezzoMedio
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/prezzoMedio> rdf:type owl:DatatypeProperty ;
                                                                                 rdfs:domain [ rdf:type owl:Class ;
                                                                                               owl:unionOf ( <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AttrazioneTuristica>
                                                                                                             <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/StrutturaRicettiva>
                                                                                                           )
                                                                                             ] ;
                                                                                 rdfs:range xsd:nonNegativeInteger ;
                                                                                 rdfs:comment "Specifica il valore del prezzo in euro."@it ;
                                                                                 rdfs:label "haPrezzo"@it .


#################################################################
#    Classes
#################################################################

###  http://dbpedia.org/ontology/City
<http://dbpedia.org/ontology/City> rdf:type owl:Class ;
                                   owl:equivalentClass <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Citta> ;
                                   rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AreaGeografica> .


###  http://schema.org/Apartment
<http://schema.org/Apartment> rdf:type owl:Class ;
                              owl:equivalentClass <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Appartamento> ;
                              rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/StrutturaRicettiva> .


###  http://schema.org/Hostel
<http://schema.org/Hostel> rdf:type owl:Class ;
                           owl:equivalentClass <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Ostello> ;
                           rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/StrutturaRicettiva> .


###  http://schema.org/Hotel
<http://schema.org/Hotel> rdf:type owl:Class ;
                          owl:equivalentClass <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Hotel> ;
                          rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/StrutturaRicettiva> .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Aereo
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Aereo> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ,
                                                                                           [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                                    owl:onProperty <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haPuntoPartenza> ;
                                                                                                                    owl:someValuesFrom <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Aeroporto>
                                                                                                                  ]
                                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                                    owl:onProperty <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haPuntoPartenza> ;
                                                                                                                    owl:allValuesFrom <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Aeroporto>
                                                                                                                  ]
                                                                                                                ) ;
                                                                                             rdf:type owl:Class
                                                                                           ] ;
                                                                           owl:disjointWith <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Treno> ;
                                                                           rdfs:comment "Aeromobile che opera su una specifica tratta aerea."@it ;
                                                                           rdfs:label "Aereo"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Aeroporto
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Aeroporto> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/InfrastrutturaTrasporto> ;
                                                                               owl:disjointWith <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/StazioneFerroviaria> ;
                                                                               rdfs:comment "Infrastruttura logistica complessa dotata di piste e terminal per il decollo, l'atterraggio e il transito dei voli."@it ;
                                                                               rdfs:label "Aeroporto"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Appartamento
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Appartamento> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/StrutturaRicettiva> ;
                                                                                  owl:disjointWith <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Hotel> ,
                                                                                                   <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Ostello> ;
                                                                                  rdfs:comment "Struttura ricettiva che comprende interi appartamenti compresi di forniture e servizi necessari all'intero soggiorno"@it ;
                                                                                  rdfs:label "Appartamento"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AreaGeografica
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AreaGeografica> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/EntitaGeografica> ;
                                                                                    rdfs:comment "Porzione di territorio spazialmente, come una nazione, una regione o una città."@it ;
                                                                                    rdfs:label "AreaGeografica"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AttrazioneTuristica
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AttrazioneTuristica> rdf:type owl:Class ;
                                                                                         rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/PuntoInteresse> ;
                                                                                         rdfs:comment "Luogo, monumento, museo o area naturale di interesse culturale, storico, o di svago per i visitatori."@it ;
                                                                                         rdfs:label "AttrazioneTuristica"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Citta
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Citta> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AreaGeografica> ;
                                                                           owl:disjointWith <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Continente> ,
                                                                                            <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Nazione> ;
                                                                           rdfs:comment "Centro abitato caratterizzato da un'elevata densità di popolazione e funzioni amministrative."@it ;
                                                                           rdfs:label "Città"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Compagnia
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Compagnia> rdf:type owl:Class ;
                                                                               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/gestisce> ;
                                                                                                 owl:someValuesFrom <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto>
                                                                                               ] ;
                                                                               owl:disjointWith <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/EntitaGeografica> ,
                                                                                                <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Itinerario> ,
                                                                                                <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                               rdfs:comment "Organizzazione, ente o agenzia commerciale che gestisce e fornisce servizi operativi legati al trasporto pubblico o privato."@it ;
                                                                               rdfs:label "Compagnia"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Continente
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Continente> rdf:type owl:Class ;
                                                                                owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                      owl:oneOf ( <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Africa>
                                                                                                                  <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/America>
                                                                                                                  <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Antartide>
                                                                                                                  <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Asia>
                                                                                                                  <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Europa>
                                                                                                                  <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Oceania>
                                                                                                                )
                                                                                                    ] ;
                                                                                rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AreaGeografica> ,
                                                                                                [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/eSedeDi> ;
                                                                                                  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                  owl:onClass <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Nazione>
                                                                                                ] ;
                                                                                owl:disjointWith <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Nazione> ;
                                                                                rdfs:comment "Specifica la più vasta delle ripartizioni con le quali si suddividono le terre emerse della crosta terrestre."@it ;
                                                                                rdfs:label "Continente"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/EntitaGeografica
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/EntitaGeografica> rdf:type owl:Class ;
                                                                                      owl:disjointWith <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Itinerario> ,
                                                                                                       <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                                      rdfs:comment "Qualsiasi elemento fisico, spaziale o amministrativo dotato di una specifica collocazione sul territorio."@it ;
                                                                                      rdfs:label "EntitàGeografica"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Hotel
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Hotel> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/StrutturaRicettiva> ;
                                                                           owl:disjointWith <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Ostello> ;
                                                                           rdfs:comment "Struttura ricettiva alberghiera che offre alloggio in camere arredate e servizi accessori."@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/InfrastrutturaTrasporto
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/InfrastrutturaTrasporto> rdf:type owl:Class ;
                                                                                             rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/PuntoInteresse> ;
                                                                                             rdfs:comment "Nodo logistico (es. stazione, aeroporto o fermata) progettato per supportare l'accesso alle reti di mobilità."@it ;
                                                                                             rdfs:label "InfrastrutturaTrasporto"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Itinerario
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Itinerario> rdf:type owl:Class ;
                                                                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/haTappa> ;
                                                                                                  owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                                                                  owl:onClass <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/PuntoInteresse>
                                                                                                ] ;
                                                                                owl:disjointWith <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto> ;
                                                                                rdfs:comment "Percorso turistico programmato, costituito da una sequenza organizzata di tappe."@it ;
                                                                                rdfs:label "Itinerario"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/MezzoDiTrasporto
