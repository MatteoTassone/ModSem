@prefix : <http://www.semanticweb.org/matte/ontologies/2026/3/turismo-mobilita-inferred#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/matte/ontologies/2026/3/turismo-mobilita-inferred> .

<http://www.semanticweb.org/matte/ontologies/2026/3/turismo-mobilita-inferred> rdf:type owl:Ontology ;
                                                                                <http://purl.org/dc/elements/1.1/creator> "Matteo Tassone"@it ;
                                                                                <http://purl.org/dc/elements/1.1/date> "2026-04-10" ;
                                                                                <http://purl.org/dc/elements/1.1/description> "L'ontologia \"Turismo e Mobilità\" modella il sistema logistico e spaziale che ruota attorno all'esperienza di viaggio. L'ontologia rappresenta l'intersezione tra la localizzazione geografica, le strutture ricettive, le attrazioni culturali e le infrastrutture di trasporto che ne consentono l'accessibilità."@it ;
                                                                                <http://purl.org/dc/elements/1.1/title> "Ontologia del Turismo e della Mobilità"@it ;
                                                                                <http://purl.org/vocab/vann/preferredNamespacePrefix> "tm" ;
                                                                                <http://purl.org/vocab/vann/preferredNamespaceUri> "http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/"^^xsd:anyURI ;
                                                                                rdfs:label "Tourism and Mobility"@en ,
                                                                                           "Turismo e Mobilità"@it .

