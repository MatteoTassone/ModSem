                                                                                               owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                               owl:onClass <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Citta>
                                                                                             ] ;
                                                                             rdfs:comment "Entità territoriale sovrana, definita da confini geografici riconosciuti."@it ;
                                                                             rdfs:label "Nazione"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Ostello
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Ostello> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/StrutturaRicettiva> ;
                                                                             rdfs:comment "Struttura ricettiva economica con camerate condivise, spazi comuni e servizi igienici spesso in condivisione."@it ;
                                                                             rdfs:label "Ostello"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Parco
<http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Parco> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/AttrazioneTuristica> ;
                                                                           rdfs:comment "Area naturale o urbana delimitata, tutelata per il suo valore ambientale o ricreativo."@it ;
                                                                           rdfs:label "Parco"@it .


###  http://www.semanticweb.org/matteo/ontologies/2026/turismo-mobilita/Pullman
